    ["$"] = {Letter = "$", Name = "Shapeform", Class = "form",
        Hint = "Sculpts a body. Attach letters and each letterform is the shape it takes — $O a ring, $I a pillar, $T a crossbeam on a post. More $ marks make it larger."},
} :: {[string]: RuneEntry}

function module.Get(letter: string): RuneEntry
    return module.Registry[letter] or {Letter = letter, Name = letter, Class = "unknown"}
end

return module
