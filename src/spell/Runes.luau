        Hint = "Bends the cast counter-clockwise as it travels. Stack for a tighter curve."},
    [")"] = {Letter = ")", Name = "Sunwise", Class = "motion", Motion = "curl_cw",
        Hint = "Bends the cast clockwise as it travels. Stack for a tighter curve."},
    ["."] = {Letter = ".", Name = "Mote", Class = "motion", Motion = "motes",
        Hint = "The cast scatters into separate motes instead of one stream — one more per dot."},
    ["&"] = {Letter = "&", Name = "Coil", Class = "motion", Motion = "coil",
        Hint = "The cast coils along its path — one turn per coil rune."},
    ["<"] = {Letter = "<", Name = "Trace", Class = "motion", Motion = "homing",
