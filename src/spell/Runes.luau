export type RuneClass = "shape" | "element" | "modifier" | "aspect" | "target" | "flow" | "motion" | "form" | "unknown"

export type RuneEntry = {
    Letter: string,
    Name: string,
    Class: RuneClass,
    Element: string?,
    Target: string?,
    Flow: string?,
    Motion: string?,
    Hint: string?,
}

local module = {}

module.Registry = {
    A = {Letter = "A", Name = "Arrow", Class = "shape",
        Hint = "Inward force; repetition is power. Where it sits on the border decides where the spell pushes — it fires out the far side."},

    B = {Letter = "B", Name = "Ember", Class = "element", Element = "Fire",
        Hint = "Fire. A cluster (BBB) is a sigil source in the core; tacked onto a glyph (AAAB) it binds fire to it."},
    W = {Letter = "W", Name = "Tide", Class = "element", Element = "Water",
        Hint = "Water. Sigil as a cluster, binding as a modifier."},
    Z = {Letter = "Z", Name = "Zephyr", Class = "element", Element = "Air",
        Hint = "Air. Sigil as a cluster, binding as a modifier."},
    G = {Letter = "G", Name = "Stone", Class = "element", Element = "Ground",
        Hint = "Ground. Sigil as a cluster, binding as a modifier."},
    J = {Letter = "J", Name = "Jiva", Class = "element", Element = "Life",
        Hint = "Life itself. Sigil or binding; on a Query ring (QJ{ }) the circle triggers when life is found."},
