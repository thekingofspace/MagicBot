    ["%"] = {Letter = "%", Name = "Rot", Class = "element", Element = "Decay",
        Hint = "Decay. Alone it festers; merged into any other spell it corrupts it. With ruin it becomes Oblivion."},
    ["/"] = {Letter = "/", Name = "Rend", Class = "element", Element = "Ruin",
        Hint = "Destruction. Alone it cleaves; merged into any other spell it corrupts it. With decay it becomes Oblivion."},
    [":"] = {Letter = ":", Name = "Aeon", Class = "element", Element = "Time",
        Hint = "Time. Sigil or binding — slow it, age it, hold it. Mixes with every element."},

    R = {Letter = "R", Name = "Reach", Class = "modifier",
        Hint = "On a glyph: stretches it across two border positions. As its own cluster or on a ring: widens the whole spell."},

    C = {Letter = "C", Name = "Craft", Class = "aspect",
        Hint = "Creates. Bind an element to choose what (CCCG creates ground); targets choose where."},
    D = {Letter = "D", Name = "Doom", Class = "aspect",
        Hint = "Unmakes. Aim it with targets (DDOE unmakes the essence of others)."},
    L = {Letter = "L", Name = "Lumen", Class = "aspect",
        Hint = "Sheds light upon its targets, or its surroundings if unaimed."},
    F = {Letter = "F", Name = "Fathom", Class = "aspect",
        Hint = "Seeks. Bind an element to hunt it (FFJ seeks life); targets to hunt things."},
    K = {Letter = "K", Name = "Kindred", Class = "aspect",
        Hint = "Copies. KKES copies essence into the self."},
    M = {Letter = "M", Name = "Missive", Class = "aspect",
        Hint = "Carries word to its targets — a distant ear if unaimed."},
